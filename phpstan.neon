parameters:
    level: max
    paths:
        - src
        - Tests
    ignoreErrors:
        - identifier: missingType.iterableValue
        -
            message: '#Call to method \w+\(\) on an unknown class Symfony\\Component\\Config\\Definition\\Builder\\NodeBuilder<.*>#'
            path: src/Docker/Configuration/

includes:
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-symfony/extension.neon
    - phpstan-baseline.neon
